*.cso
*.dxil
*.hlsl.bin
*.dump
*.tmp
*.temp

# -----------------------------------------------------------------------------
# NuGet / DXC runtime packages downloaded locally
# -----------------------------------------------------------------------------
/packages/
*.nupkg

# -----------------------------------------------------------------------------
# Editor / OS noise
# -----------------------------------------------------------------------------
.vscode/.browse.VC.db*
.vscode/ipch/
.idea/
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Local overlay folders copied from ChatGPT answers
# -----------------------------------------------------------------------------
D3D12Helper_*_overlay/
D3D12Helper_*_overlay.zip

# -----------------------------------------------------------------------------
# Local helper commands generated from ChatGPT patch ZIPs
# -----------------------------------------------------------------------------
# Do not ignore all *.cmd files because repository-maintained command scripts may
# be intentionally committed under tools/ or another source-controlled folder.
# These root-level helper commands are local workflow shortcuts only.
/build_and_test.cmd
/build_test_and_push_if_passed.cmd
/git_commit_push.cmd
